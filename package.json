{
  "name": "archaeologist-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env PRISMA_CLIENT_ENGINE_TYPE=dataproxy next dev",
    "build": "cross-env PRISMA_CLIENT_ENGINE_TYPE=dataproxy next build",
    "start": "cross-env PRISMA_CLIENT_ENGINE_TYPE=dataproxy next start",
    "test": "vitest run",
    "db:push": "prisma db push",
    "db:reset:test": "cross-env DATABASE_URL=postgresql://postgres:postgres@localhost:5433/archaeologist_test prisma migrate reset --force",
    "prisma:generate": "prisma generate --no-engine",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/client": "6.9.0",
    "ai": "^6.0.116",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "prisma": "6.9.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "simple-git": "^3.33.0",
    "trigger.dev": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.1.0",
    "autoprefixer": "^10.4.27",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^29.0.0",
    "msw": "^2.12.11",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "3.4.4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0"
  }
}
