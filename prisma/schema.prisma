generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model HealthCheck {
  id        String   @id @default(cuid())
  message   String
  createdAt DateTime @default(now())
}

model Repository {
  id  String @id @default(uuid())
  url String @unique

  owner    String
  name     String
  provider String @default("github")

  createdAt DateTime @default(now())

  scans RepositoryScan[]
  files RepositoryFile[]
}

model RepositoryScan {
  id String @id @default(uuid())

  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id])

  status String

  filesCount Int @default(0)

  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  files RepositoryFile[]

  @@index([repositoryId])
}

model RepositoryFile {
  id String @id @default(uuid())

  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id])

  scanId String
  scan   RepositoryScan @relation(fields: [scanId], references: [id])

  path String
  size Int

  hash String?

  createdAt DateTime @default(now())

  @@unique([repositoryId, path])
  @@index([repositoryId])
  @@index([scanId])
}
