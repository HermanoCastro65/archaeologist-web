generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model HealthCheck {
  id        String   @id @default(cuid())
  message   String
  createdAt DateTime @default(now())
}

model Repository {

  id        String   @id @default(uuid())
  url       String   @unique

  owner     String
  name      String
  provider  String   @default("github")

  createdAt DateTime @default(now())

}