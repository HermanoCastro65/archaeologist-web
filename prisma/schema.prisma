generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String?  @unique
  emailVerified DateTime?
  image         String?

  createdAt DateTime @default(now())

  accounts Account[]
  sessions Session[]

  repositories Repository[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model HealthCheck {
  id        String   @id @default(cuid())
  message   String
  createdAt DateTime @default(now())
}

model Repository {
  id  String @id @default(uuid())
  url String

  owner    String
  name     String
  provider String @default("github")

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  isArchived Boolean @default(false)

  createdAt DateTime @default(now())

  scans RepositoryScan[]
  files RepositoryFile[]

  @@unique([url, userId])
}

model RepositoryScan {
  id String @id @default(uuid())

  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id])

  status String

  filesCount Int @default(0)

  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  files RepositoryFile[]

  @@index([repositoryId])
}

model RepositoryFile {
  id String @id @default(uuid())

  repositoryId String
  repository   Repository @relation(fields: [repositoryId], references: [id])

  scanId String
  scan   RepositoryScan @relation(fields: [scanId], references: [id])

  path String
  size Int

  hash String?

  isArchived Boolean @default(false)
  deletedAt  DateTime?

  createdAt DateTime @default(now())

  @@unique([repositoryId, path])
  @@index([repositoryId])
  @@index([scanId])
  @@index([isArchived])
}